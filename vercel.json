{
  "version": 2,
  "name": "trycycle",
  "alias": ["trycycle.vercel.app"],
  "env": {
    "CSRF_SECRET": "@csrf-secret"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}